@model Produtor

<h1>Deletar cadastro</h1>

<h2 style="font-size: 19px" class="text-dark">Você tem certeza que deseja deletar esse cadastro permanentemente?</h2>

<div>
    <h4>Produtor</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Nome)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Nome)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Cpf)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Cpf)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Industria)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Industria)
        </dd>
    </dl>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div>
        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary gradient-button">Voltar</a>
        <input type="submit" style="float: right;" value="Deletar" class="btn btn-danger" />
    </div>
}


