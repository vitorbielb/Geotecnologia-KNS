@{
    Layout = null;
}

@model Solicitacao

<div id="file-upload-content">
    <div class="card">
        <div class="card-body">

            <div class="modal fade" id="deletefileModal" tabindex="-1" aria-labelledby="deletefileModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h1 class="modal-title fs-5" id="deletefileModalLabel">Deseja excluir este arquivo?</h1>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                            <button type="button" class="btn btn-danger">Confirmar</button>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.Documentos?.Any() ?? false)
            {
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>@Html.DisplayNameFor(model => model.Documentos![0].Descricao)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Documentos)
                            {
                                <tr>
                                    <td>
                                        @Html.DisplayFor(model => item.Descricao)
                                        <input type="hidden" class="hidden" value="@item.Id">
                                    </td>
                                    <td style="text-align: right;">
                                        <a class="btn btn-primary gradient-button" target="_blank" href="@Url.Action("ViewFile", "Solicitacoes", values: new { item.Id })">
                                            <i class="bi bi-eye-fill"></i>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-eye-fill" viewBox="0 0 16 16">
                                                <path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z" />
                                                <path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8zm8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7z" />
                                            </svg>
                                        </a>

                                        <button type="button" class="btn btn-primary gradient-button" data-bs-toggle="modal" data-bs-target="#deletefileModal" onclick="setdeletefilemodal($(this))">
                                            <i class="bi bi-trash3-fill"></i>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                                                <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5Zm-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5ZM4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06Zm6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528ZM8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5Z" />
                                            </svg>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p>Nenhum documento</p>
            }
        </div>

    </div>
</div>
