@page
@model LoginModel

@{
    Layout = "_NoContent";
}

<!-- Section: Design Block -->
<section class="background-radial-gradient overflow-hidden">
    <style>
        .login {
            min-height: 100vh;
        }

        .bg-image {
            background-image: linear-gradient(rgba(0, 100, 200, 0.0), rgba(0, 180, 255, 0.0)), url('/images/login-background4.jpeg');
            background-size: cover;
            background-position: center;
        }

        .login-heading {
            font-weight: 300;
        }

        .btn-login {
            font-size: 0.9rem;
            letter-spacing: 0.05rem;
            padding: 0.75rem 1rem;
        }

    </style>

    <!-- html -->
    <div class="container-fluid ps-md-0">
        <div class="row g-0">
            <div class="d-none d-md-flex col-md-4 col-lg-6 bg-image"></div>
            <div class="col-md-8 col-lg-6">
                <div class="login d-flex align-items-center py-5">
                    <div class="container">
                        <div class="row">
                            <div class="col-12 text-center">
                                <img width="241" height="89"
                                     style="padding-left: 40px; padding-bottom: 30px; padding-right: 40px; padding-top: 0px;"
                                     src="https://knsambiental.com.br/wp-content/uploads/2022/03/logo-kns-ambiental-ok.png" class="attachment-full size-full wp-image-1939" alt="">
                            </div>
                            <div class="col-md-9 col-lg-8 mx-auto">
                                <h3 class="login-heading mb-4">Bem vindo(a)</h3>

                                <!-- Sign In Form -->
                                <form id="account" method="post">
                                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                                    <div class="form-floating mb-3">
                                        <input asp-for="Input.Email" type="email" class="form-control" id="floatingInput" placeholder="name@example.com">
                                        <label asp-for="Input.Email" for="floatingInput">Email</label>
                                    </div>
                                    <div class="form-floating mb-3">
                                        <input asp-for="Input.Password" type="password" class="form-control" id="floatingPassword" placeholder="Password">
                                        <label asp-for="Input.Password" for="floatingPassword">Senha</label>
                                    </div>

                                    <div class="form-check mb-3">
                                        <input asp-for="Input.RememberMe" type="hidden" value="false">
                                        <input class="form-check-input" type="checkbox" id="rememberPasswordCheck" style="margin-left: 0px;" onclick="switchCheckBoxValue($(this))">
                                        <label asp-for="Input.RememberMe" class="form-check-label" for="rememberPasswordCheck">
                                            Lembrar senha
                                        </label>
                                    </div>

                                    <div class="d-grid">
                                        <button id="login-submit" type="submit" class="btn btn-lg btn-primary btn-login text-uppercase fw-bold mb-2">Entrar</button>
                                        <div class="text-center">
                                            <a class="small" href="#">Esqueceu senha?</a>
                                        </div>
                                        <div class="text-center">
                                            <a class="small" href="#">Solicitar demonstração</a>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/areas/identity/pages/account/login.js"></script>
}
