@model IEnumerable<GeotecnologiaKNS.Models.Cartografia>

@{
    ViewData["Title"] = "Cartografias";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Propriedades</h4>

                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr style="background-color: #FFF; color: #258cfb;">
                                <th>@Html.DisplayNameFor(model => model.First().Propriedade)</th>
                                <th>Arquivo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="table-row-link" data-url="@Url.Action("Edit", "Cartografias", new { id = item.Id })" style="cursor: pointer;">
                                    <td>@item.Propriedade?.NomePropriedade</td>
                                    <td>Cartográfico</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="text-start">
    <button type="button" class="btn btn-primary gradient-button" onclick="location.href='@Url.Action("Create")'">
        <i class="bi bi-plus-circle"></i>
        Nova propriedade
    </button>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.table-row-link').forEach(row => {
            row.addEventListener('click', function () {
                const url = this.dataset.url;
                if (url) {
                    window.location.href = url;
                }
            });
        });
    </script>
}