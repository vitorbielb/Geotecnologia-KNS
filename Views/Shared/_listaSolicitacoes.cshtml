@using GeotecnologiaKNS.Views
@model IEnumerable<Solicitacao>

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <p class="card-description">
                </p>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr style="background-color: #FFF; color: #258cfb;">
                                <th>
                                    @Html.DisplayNameFor(model => model.Propriedade)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.Solicitante)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.DataSolicitacao)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.Analista)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.DataAnalise)
                                </th>
                                <th>
                                    @Html.DisplayNameFor(model => model.Status)
                                </th>
                            </tr>
                        </thead>
                        @foreach (var solicitacao in Model)
                        {
                            <tr class="table-row-link" @*data-url="@Url.Action("Edit", "Produtores", new { id = produtor.Id })"*@>
                                <td>@Html.DisplayFor(x => solicitacao.Propriedade.NomePropriedade)</td>
                                <td>@Html.DisplayFor(x => solicitacao.Solicitante)</td>
                                <td>@Html.DisplayFor(x => solicitacao.DataSolicitacao)</td>
                                <td>@Html.DisplayFor(x => solicitacao.Analista)</td>
                                <td>@Html.DisplayFor(x => solicitacao.DataAnalise)</td>
                                <td>@Html.DisplayStatusFor(x => solicitacao.Status)</td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>