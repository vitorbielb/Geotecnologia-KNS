@model GeotecnologiaKNS.Models.Industria

<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Editar Indústria</h4>
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="TenantId" />
                    <div class="form-group">
                        <label asp-for="Imagem" class="control-label"></label>
                        <input type="file" asp-for="Imagem" class="form-control">
                        <span asp-validation-for="Imagem" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Nome" class="control-label"></label>
                        <input asp-for="Nome" class="form-control" />
                        <span asp-validation-for="Nome" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="NomeResumido" class="control-label"></label>
                        <input asp-for="NomeResumido" class="form-control" />
                        <span asp-validation-for="NomeResumido" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="RazaoSocial" class="control-label"></label>
                        <input asp-for="RazaoSocial" class="form-control" />
                        <span asp-validation-for="RazaoSocial" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Cnpj" class="control-label"></label>
                        <input asp-for="Cnpj" class="form-control" />
                        <span asp-validation-for="Cnpj" class="text-danger"></span>
                    </div>
                    <div class="form-group" style="margin-top: 40px;">
                        <a type="submit" href="/Industrias/Index" class="btn btn-secondary">Voltar</a>
                    </div>
                    <div style="float: right; margin-top: -60px;">
                        <button type="submit" class="btn btn-primary gradient-button">
                            <i class="bi bi-check-circle-fill"></i>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                            </svg>
                            Salvar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

