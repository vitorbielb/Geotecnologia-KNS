@model GeotecnologiaKNS.Models.Cartografia
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Create";
}

<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Nova Solicitação</h4>
                <div class="row">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="form-group">
                            <label asp-for="PropriedadeId" class="control-label"></label>
                            <select asp-for="PropriedadeId" class="form-control form-control-sm" asp-items="ViewBag.Propriedades"></select>
                            <span asp-validation-for="Tipo" class="text-danger"></span>
                        </div>
                        <div class="form-group select-with-icon">
                            <label asp-for="Tipo" class="control-label"></label>
                            <div class="select-wrapper">
                                <select asp-for="Tipo" class="form-control form-control-sm">
                                    <option value="">Selecione...</option>
                                    <option value="SUC">Sobrep. Unidade de Conservação</option>
                                    <option value="STI">Sobrep. Terra Indígena</option>
                                    <option value="SQ">Sobrep. Quilombolas</option>
                                    <option value="SOP">Sobrep. Outros Perímetos</option>
                                    <option value="SEI">Sobrep. Embargo IBAMA</option>
                                    <option value="DAEI">Distância Área Embargada IBAMA</option>
                                    <option value="DETER">DETER</option>
                                    <option value="IP">Incapacidade Produtiva</option>
                                    <option value="LB">Localização Bioma</option>
                                    <option value="UPC">Unidade Produtiva Contínua</option>
                                    <option value="PA">Perímetro Adulterado</option>
                                    <option value="OE">Outras Evidências</option>
                                    <option value="IP7">Imagem PRODES 2007</option>
                                    <option value="IP8">Imagem PRODES 2008</option>
                                    <option value="IP9">Imagem PRODES 2009</option>
                                    <option value="IP10">Imagem PRODES 2010</option>
                                    <option value="IP11">Imagem PRODES 2011</option>
                                    <option value="IP12">Imagem PRODES 2012</option>
                                    <option value="IP13">Imagem PRODES 2013</option>
                                    <option value="IP14">Imagem PRODES 2014</option>
                                    <option value="IP15">Imagem PRODES 2015</option>
                                    <option value="IP16">Imagem PRODES 2016</option>
                                    <option value="IP17">Imagem PRODES 2017</option>
                                    <option value="IP18">Imagem PRODES 2018</option>
                                    <option value="IP19">Imagem PRODES 2019</option>
                                    <option value="IP20">Imagem PRODES 2020</option>
                                    <option value="ZI">Zona de influência</option>
                                    <option value="MF">Mapa fundiário</option>
                                    <option value="UC">Uso do solo e Cobertura</option>
                                </select>
                            </div>
                            <span asp-validation-for="Tipo" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 text-start">
                                <a asp-action="Index" class="btn btn-secondary">Voltar</a>
                            </div>
                            <div class="col-md-6 text-end">
                                <button type="submit" class="btn btn-primary gradient-button">
                                    <i class="bi bi-check-circle-fill"></i>
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                                        <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                                    </svg>
                                    Ir para envio de arquivos
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
    {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    }
