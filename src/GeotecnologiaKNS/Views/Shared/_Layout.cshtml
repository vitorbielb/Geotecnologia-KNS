<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@ViewData["Title"] - GeotecnologiaKNS</title>
    <link rel="stylesheet" href="~/vendors/mdi/css/materialdesignicons.min.css" asp-append-version="true">
    <link rel="stylesheet" href="~/vendors/base/vendor.bundle.base.css" asp-append-version="true">
    <link rel="stylesheet" href="~/vendors/datatables.net-bs4/dataTables.bootstrap4.css">
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="shortcut icon" href="~/images/favicon.png" />
</head>
<body>
    <div class="container-scroller">
        <partial name="_navbar"></partial>

        <div class="container-fluid page-body-wrapper">
            <partial name="_sidebar"></partial>
            <div class="main-panel">
                <div class="content-wrapper">
                    <main role="main" class="pb-3">
                        @RenderBody()
                    </main>
                </div>
                <partial name="_footer"></partial>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/vendors/base/vendor.bundle.base.js"></script>
    <script src="~/js/chart.js"></script>
    <script src="~/vendors/chart.js/Chart.min.js"></script>
    <script src="~/vendors/datatables.net/jquery.dataTables.js"></script>
    <script src="~/vendors/datatables.net-bs4/dataTables.bootstrap4.js"></script>
    <script src="~/js/off-canvas.js"></script>
    <script src="~/js/hoverable-collapse.js"></script>
    <script src="~/js/template.js"></script>
    <script src="~/js/dashboard.js"></script>
    <script src="~/js/data-table.js"></script>
    <script src="~/js/jquery.dataTables.js"></script>
    <script src="~/js/site.js"></script>
    <script src="~/js/dataTables.bootstrap4.js"></script>
    <script src="~/js/jquery.cookie.js" type="text/javascript"></script>
    <script src="~/js/file-upload.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
