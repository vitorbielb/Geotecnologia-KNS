@model GeotecnologiaKNS.Models.Solicitacao
@inject GeotecnologiaKNS.Repositories.Interfaces.ISolicitacaoRepository repository
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .shaded-container {
            padding: 20px;
            background-color: #ffffff;
            box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
        }
    </style>
</head>

<div class="shaded-container" style="margin-bottom: 10px">
    <div class="row">
        <div class="col-md-3">
            <div class="form-group">
                <label asp-for="Propriedade.Produtor.Nome" class="control-label"></label>
                <div>@Model.Propriedade.Produtor.Nome</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label asp-for="Propriedade.NomePropriedade" class="control-label"></label>
                <div>@Model.Propriedade.NomePropriedade</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label asp-for="Propriedade.UnidadeFederativa" class="control-label"></label>
                <div>@Model.Propriedade.UnidadeFederativa</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label asp-for="Propriedade.Municipio" class="control-label"></label>
                <div>@Model.Propriedade.Municipio</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label asp-for="Propriedade.Produtor.Cpf" class="control-label"></label>
                <div>@Model.Propriedade.Produtor.Cpf</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label asp-for="Propriedade.Produtor.Id" class="control-label"></label>
                <div>@Model.Propriedade.Produtor.Id</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label asp-for="Propriedade.Id" class="control-label"></label>
                <div>@Model.Propriedade.Id</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label asp-for="Propriedade.CicloProducao" class="control-label"></label>
                <div>@Model.Propriedade.CicloProducao</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label asp-for="Propriedade.Area" class="control-label"></label>
                <div>@Model.Propriedade.Area</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label asp-for="Propriedade.AreaUtil" class="control-label"></label>
                <div>@Model.Propriedade.AreaUtil</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label asp-for="Propriedade.Latitude" class="control-label"></label>
                <div>@Model.Propriedade.Latitude</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-group">
                <label asp-for="Propriedade.Longitude" class="control-label"></label>
                <div>@Model.Propriedade.Longitude</div>
            </div>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <div class="col-md-3">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-3">Propriedade Id:</dt>
                            <dd class="col-sm-9">@Model.PropriedadeId</dd>

                            <dt class="col-sm-3">Analista:</dt>
                            <dd class="col-sm-9">@Model.Analista</dd>
                        </dl>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-3">Solicitante:</dt>
                            <dd class="col-sm-9">@Model.Solicitante</dd>

                            <dt class="col-sm-3">Data de Solicitação:</dt>
                            <dd class="col-sm-9">@Model.DataSolicitacao</dd>
                        </dl>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-3">Data de Análise:</dt>
                            <dd class="col-sm-9">@Model.DataAnalise</dd>

                            <dt class="col-sm-3">Observação:</dt>
                            <dd class="col-sm-9">@Model.Observacao</dd>
                        </dl>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="col-md-6">
                        <dl class="row">
                            <dt class="col-sm-3">Status:</dt>
                            <dd class="col-sm-9">@Model.Status</dd>

                            <dt class="col-sm-3">Parecer:</dt>
                            <dd class="col-sm-9">@Model.Parecer</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <ul class="nav nav-tabs" id="myTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="home-tab" data-bs-toggle="tab" data-bs-target="#home" type="button" role="tab" aria-controls="home" aria-selected="true">Vinculo</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile" type="button" role="tab" aria-controls="profile" aria-selected="false">Outras solicitações</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="contact-tab" data-bs-toggle="tab" data-bs-target="#contact" type="button" role="tab" aria-controls="contact" aria-selected="false">Documentos</button>
                    </li>
                </ul>
                <div class="tab-content" id="myTabContent">
                    <div class="tab-pane fade show active" id="home" role="tabpanel" aria-labelledby="home-tab">
                        <partial name="_produtorPropriedade" model="Model.Propriedade.Produtor.Propriedades"></partial>
                    </div>
                    <div class="tab-pane fade" id="profile" role="tabpanel" aria-labelledby="profile-tab">
                        <partial name="_listaSolicitacoes" model="repository.GetSolicitacoesByProdutor(Model.Propriedade.Produtor.Id).Where(x => x != Model)"></partial>
                    </div>
                    <div class="tab-pane fade" id="contact" role="tabpanel" aria-labelledby="contact-tab">
                        <partial name="_file-list" model="Model.Propriedade"></partial>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
