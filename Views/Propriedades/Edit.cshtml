@model GeotecnologiaKNS.Models.Propriedade

<head>
    <link rel="stylesheet" href="C:\Users\vitor\source\repos\GeotecnologiaKNS\wwwroot\css\site.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<h1 style="font-size: 50px;">Propriedade</h1>

<h4>Editar</h4>
<hr />
<form asp-action="Edit">
    <div class="row">
        <div class="col-md-3">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <!-- Grupo 1 -->
            <div class="form-group">
                <label asp-for="NomePropriedade" class="control-label"></label>
                <input asp-for="NomePropriedade" class="form-control" />
                @Html.ValidationMessageFor(model => model.NomePropriedade, "", new { @class = "error-message" })
            </div>
            <div class="form-group select-with-icon">
                <label asp-for="Bioma" class="control-label"></label>
                <div class="select-wrapper">
                    <select asp-for="Bioma" class="form-control">
                        <option value="">Selecione...</option>
                        <option value="Amazonia">Amazônia</option>
                        <option value="Cerrado">Cerrado</option>
                        <option value="MataAtlantica">Mata Atlântica</option>
                        <option value="Caatinga">Caatinga</option>
                        <option value="Pantanal">Pantanal</option>
                        <option value="Pampas">Pampas</option>
                    </select>
                    <span class="arrow-down"><i class="fas fa-chevron-down"></i></span>
                </div>
                @Html.ValidationMessageFor(model => model.Bioma, "", new { @class = "error-message" })
            </div>
            <div class="form-group select-with-icon">
                <label asp-for="UnidadeFederativa" class="control-label"></label>
                <div class="select-wrapper">
                    <select asp-for="UnidadeFederativa" class="form-control" asp-items="UnidadesFederativasExtension.GetUnidadesFederativas()" onchange="populateCities(this.value)"></select>
                    <span class="arrow-down"><i class="fas fa-chevron-down"></i></span>
                </div>
                @Html.ValidationMessageFor(model => model.UnidadeFederativa, "", new { @class = "error-message" })
            </div>
            <div class="form-group">
                <label asp-for="Municipio" class="control-label"></label>
                <input asp-for="Municipio" class="form-control" />
                <span asp-validation-for="Municipio" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-3">
            <!-- Grupo 2 -->
            <div class="form-group select-with-icon">
                <label asp-for="TipoPropriedade" class="control-label"></label>
                <div class="select-wrapper">
                    <select asp-for="TipoPropriedade" class="form-control">
                        <option value="">Selecione...</option>
                        <option value="Confinamento">Confinamento</option>
                        <option value="PropriedadeRural">Propriedade Rural</option>
                    </select>
                    <span class="arrow-down"><i class="fas fa-chevron-down"></i></span>
                </div>
                @Html.ValidationMessageFor(model => model.TipoPropriedade, "", new { @class = "error-message" })
            </div>
            <div class="form-group select-with-icon">
                <label asp-for="CicloProducao" class="control-label"></label>
                <div class="select-wrapper">
                    <select asp-for="CicloProducao" class="form-control">
                        <option value="">Selecione...</option>
                        <option value="CRIA">CRIA</option>
                        <option value="RECRIA">RECRIA</option>
                        <option value="ENGORDA">ENGORDA</option>
                        <option value="CRIARECRIA">CRIA RECRIA</option>
                        <option value="RECRIAENGORDA">RECRIA ENGORDA</option>
                        <option value="CICLOCOMPLETO">CICLO COMPLETO</option>
                        <option value="NAOINFORMADO">NÃO INFORMADO</option>
                    </select>
                    <span class="arrow-down"><i class="fas fa-chevron-down"></i></span>
                </div>
                @Html.ValidationMessageFor(model => model.CicloProducao, "", new { @class = "error-message" })
            </div>
            <div class="form-group">
                <label asp-for="Industria" class="control-label"></label>
                <input asp-for="Industria" class="form-control" />

                @Html.ValidationMessageFor(model => model.Industria, "", new { @class = "error-message" })
            </div>
        </div>
        <div class="col-md-3">
            <!-- Grupo 3 -->
            <div class="form-group">
                <label asp-for="Latitude" class="control-label"></label>
                <input asp-for="Latitude" class="form-control" />
                @Html.ValidationMessageFor(model => model.Latitude, "", new { @class = "error-message" })
            </div>
            <div class="form-group">
                <label asp-for="Area" class="control-label"></label>
                <input asp-for="Area" class="form-control" />
                @Html.ValidationMessageFor(model => model.Area, "", new { @class = "error-message" })
            </div>
            <div class="form-group">
                <label asp-for="CadastroAmbientalRural" class="control-label"></label>
                <input asp-for="CadastroAmbientalRural" class="form-control" />

                @Html.ValidationMessageFor(model => model.CadastroAmbientalRural, "", new { @class = "error-message" })
            </div>
        </div>
        <div class="col-md-3">
            <!-- Grupo 4 -->
            <div class="form-group">
                <label asp-for="Longitude" class="control-label"></label>
                <input asp-for="Longitude" class="form-control" />
                @Html.ValidationMessageFor(model => model.Longitude, "", new { @class = "error-message" })
            </div>
            <div class="form-group">
                <label asp-for="AreaUtil" class="control-label"></label>
                <input asp-for="AreaUtil" class="form-control" />
                @Html.ValidationMessageFor(model => model.AreaUtil, "", new { @class = "error-message" })
            </div>
            <div class="form-group select-with-icon">
                <label asp-for="TipoCadastroRural" class="control-label"></label>
                <div class="select-wrapper">
                    <select asp-for="TipoCadastroRural" class="form-control">
                        <option value="">Selecione...</option>
                        <option value="SicarRecibo">Sicar - Recibo</option>
                        <option value="SicarProtocolo">Sicar/Protocolo</option>
                        <option value="CarEstadual">Car Estadual</option>
                        <option value="CodigoSenacsa">Código Senacsa</option>
                        <option value="RSPP">RSPP</option>
                        <option value="RENSPA">RENSPA</option>
                        <option value="DICOSE">DICOSE</option>
                    </select>
                    <span class="arrow-down"><i class="fas fa-chevron-down"></i></span>
                </div>
                @Html.ValidationMessageFor(model => model.TipoCadastroRural, "", new { @class = "error-message" })
            </div>
        </div>
    </div>

    <div class="form-group" style="margin-top: 40px;">
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
    <div style="float: right;">
        <button type="submit" class="btn btn-primary gradient-button">
            <i class="bi bi-check-circle-fill"></i>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
            </svg>
            Salvar
        </button>
        <a href="@Url.Action("Delete", "Propriedades", new { id = Model.Id })" class="btn btn-primary gradient-button">
            <i class="bi bi-trash3-fill"></i>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5Zm-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5ZM4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06Zm6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528ZM8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5Z" />
            </svg>
            Excluir
        </a>
    </div>
</form>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
<body>
    <div class="conteudo-superior">
        <div class="tabs">
            <div class="tabs__sidebar">
                <button class="tabs__button active" data-for-tab="1" onclick="selecionarGuia(this)">Vínculos</button>
                <button class="tabs__button" data-for-tab="2" onclick="selecionarGuia(this)">Solicitação</button>
                <button class="tabs__button" data-for-tab="3" onclick="selecionarGuia(this)">Documentos</button>
            </div>
            <div class="tabs__content" data-tab="1">
                <h2>Vínculo</h2>
                <p>Propriedade</p>
            </div>
            <div class="tabs__content" data-tab="2">
                <h2>Solicitação</h2>
                <p>Situação</p>
            </div>
            <div class="tabs__content" data-tab="3">
                <h2>Documentos</h2>
                <p>Nenhum documento</p>
            </div>
        </div>
        <script>
            function selecionarGuia(botao) {
                const tabsContainer = document.querySelector('.tabs');
                const tabNumber = botao.dataset.forTab;
                const tabToActivate = tabsContainer.querySelector('.tabs__content[data-tab="' + tabNumber + '"]');

                const allButtons = tabsContainer.querySelectorAll('.tabs__button');
                allButtons.forEach((button) => {
                    button.classList.remove('active');
                });

                const allTabs = tabsContainer.querySelectorAll('.tabs__content');
                allTabs.forEach((tab) => {
                    tab.classList.remove('active');
                });

                botao.classList.add('active');
                tabToActivate.classList.add('active');
            }
        </script>
    </div>
</body>

