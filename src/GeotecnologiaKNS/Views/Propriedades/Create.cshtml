@model GeotecnologiaKNS.Models.Propriedade

<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Cadastrar Propriedade</h4>
                <form asp-action="Create">
                    <div class="row">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <!-- Grupo 1 -->
                        <div class="form-group">
                            <label asp-for="NomePropriedade" class="control-label"></label>
                            <input asp-for="NomePropriedade" class="form-control" />
                            <span asp-validation-for="NomePropriedade" class="text-danger"></span>
                        </div>
                        <div class="form-group select-with-icon">
                            <label asp-for="Bioma" class="control-label"></label>
                            <div class="select-wrapper">
                                <select asp-for="Bioma" class="form-control form-control-sm">
                                    <option value="">Selecione...</option>
                                    <option value="Amazonia">Amazônia</option>
                                    <option value="Cerrado">Cerrado</option>
                                    <option value="MataAtlantica">Mata Atlântica</option>
                                    <option value="Caatinga">Caatinga</option>
                                    <option value="Pantanal">Pantanal</option>
                                    <option value="Pampas">Pampas</option>
                                </select>
                            </div>
                            <span asp-validation-for="Bioma" class="text-danger"></span>
                        </div>
                        <div class="form-group select-with-icon">
                            <label asp-for="UnidadeFederativa" class="control-label"></label>
                            <div class="select-wrapper">
                                <select asp-for="UnidadeFederativa" class="form-control form-control-sm" asp-items="ViewBag.UnidadesFederativas" onchange="populateCities(this.value)"></select>
                            </div>
                            <span asp-validation-for="Municipio" class="error-message text-danger"></span>
                        </div>
                        <div class="form-group select-with-icon">
                            <label asp-for="Municipio" class="control-label"></label>
                            <div class="select-wrapper">
                                <select asp-for="Municipio" class="form-control form-control-sm" id="citiesDropdown" disabled></select>
                            </div>
                            <span asp-validation-for="Municipio" class="text-danger"></span>
                        </div>
                        <!-- Grupo 2 -->
                        <div class="form-group select-with-icon">
                            <label asp-for="TipoPropriedade" class="control-label"></label>
                            <div class="select-wrapper">
                                <select asp-for="TipoPropriedade" class="form-control form-control-sm">
                                    <option value="">Selecione...</option>
                                    <option value="Confinamento">Confinamento</option>
                                    <option value="PropriedadeRural">Propriedade Rural</option>
                                </select>
                            </div>
                            <span asp-validation-for="TipoPropriedade" class="text-danger"></span>
                        </div>
                        <div class="form-group select-with-icon">
                            <label asp-for="CicloProducao" class="control-label"></label>
                            <div class="select-wrapper">
                                <select asp-for="CicloProducao" class="form-control form-control-sm">
                                    <option value="">Selecione...</option>
                                    <option value="CRIA">CRIA</option>
                                    <option value="RECRIA">RECRIA</option>
                                    <option value="ENGORDA">ENGORDA</option>
                                    <option value="CRIARECRIA">CRIA RECRIA</option>
                                    <option value="RECRIAENGORDA">RECRIA ENGORDA</option>
                                    <option value="CICLOCOMPLETO">CICLO COMPLETO</option>
                                    <option value="NAOINFORMADO">NÃO INFORMADO</option>
                                </select>
                            </div>
                            <span asp-validation-for="CicloProducao" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Industria" class="control-label"></label>
                            <input class="form-control" value="@User.Identity.GetIndustria()" disabled />
                            <span asp-validation-for="Industria" class="text-danger"></span>
                        </div>
                        <!-- Grupo 3 -->
                        <div class="row">
                            <div class="form-group col-6">
                                <label asp-for="Latitude" class="control-label"></label>
                                <input asp-for="Latitude" class="form-control" onchange="geozoneMapSet()" />
                                <span asp-validation-for="Latitude" class="text-danger"></span>
                            </div>
                            <div class="form-group col-6">
                                <label asp-for="Longitude" class="control-label"></label>
                                <input asp-for="Longitude" class="form-control" onchange="geozoneMapSet()" />
                                <span asp-validation-for="Longitude" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="form-group">
                            <div id="geozone-map">
                            </div>
                        </div>
                        <div class="form-group">
                            <label asp-for="Area" class="control-label"></label>
                            <input asp-for="Area" class="form-control" />
                            <span asp-validation-for="Area" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="CadastroAmbientalRural" class="control-label"></label>
                            <input asp-for="CadastroAmbientalRural" class="form-control" />
                            <span asp-validation-for="CadastroAmbientalRural" class="text-danger"></span>
                        </div>
                        <!-- Grupo 4 -->
                        <div class="form-group">
                            <label asp-for="AreaUtil" class="control-label"></label>
                            <input asp-for="AreaUtil" class="form-control" />
                            <span asp-validation-for="AreaUtil" class="text-danger"></span>
                        </div>
                        <div class="form-group select-with-icon">
                            <label asp-for="TipoCadastroRural" class="control-label"></label>
                            <div class="select-wrapper">
                                <select asp-for="TipoCadastroRural" class="form-control form-control-sm">
                                    <option value="">Selecione...</option>
                                    <option value="SicarRecibo">Sicar - Recibo</option>
                                    <option value="SicarProtocolo">Sicar/Protocolo</option>
                                    <option value="CarEstadual">Car Estadual</option>
                                    <option value="CodigoSenacsa">Código Senacsa</option>
                                    <option value="RSPP">RSPP</option>
                                    <option value="RENSPA">RENSPA</option>
                                    <option value="DICOSE">DICOSE</option>
                                </select>
                            </div>
                            <span asp-validation-for="TipoCadastroRural" class="text-danger"></span>
                        </div>

                        <div class="form-group select-with-icon">
                            <label asp-for="ProdutorId" class="control-label"></label>
                            <div class="select-wrapper">
                                <select asp-for="ProdutorId" class="form-control form-control-sm" asp-items="ViewBag.Produtores">
                                </select>
                            </div>
                            <span asp-validation-for="ProdutorId" class="error-message text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group" style="margin-top: 40px;">
                        <a type="submit" href="/Propriedades/Index" class="btn btn-secondary">Voltar</a>
                    </div>
                    <div style="float: right; margin-top: -60px;">
                        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#confirmRegistrationModal">
                            <i class="bi bi-check-circle-fill"></i>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
                                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                            </svg>
                            Cadastrar
                        </button>
                    </div>

                    <div class="modal fade" id="confirmRegistrationModal" tabindex="-1" aria-labelledby="confirmRegistrationModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h1 class="modal-title fs-5" id="confirmRegistrationModalLabel">Confirmar cadastro</h1>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <h5>ATENÇÃO! O cadastro só será considerado válido após a análise de nossa equipe técnica. Até que a análise seja concluída, ele será considerado inválido.</h5>
                                    <p>A fim de agilizar o processo de análise, é imprescindível que todos os dados da propriedade estejam corretos.</p>
                                </div>
                                <div class="modal-footer">
                                    <button style="float: left;" type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                                    <div>
                                        <button type="submit" class="btn btn-primary gradient-button">
                                            Confirmar
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/views/propriedades/create.js"></script>
}
